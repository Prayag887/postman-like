{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "App Tester",
  "version": "0.1.0",
  "identifier": "dev.prayag.apptester",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "App Tester",
        "width": 1320,
        "height": 840,
        "minWidth": 760,
        "minHeight": 620,
        "backgroundColor": "#09100f"
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Local Android traffic and runtime inspector",
    "longDescription": "Inspect Android HTTP traffic, response regressions, and correlated runtime diagnostics locally."
  }
}
